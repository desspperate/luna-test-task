# Postgres
PG_USER=payments_user
PG_PASSWORD=
PG_DB=payments_database
PG_DRIVER=postgresql+asyncpg
PG_HOST=postgres
PG_PORT=5432

# RabbitMQ
RMQ_USER=payments_user
RMQ_PASSWORD=
RMQ_HOST=rabbitmq
RMQ_PORT=5672
RMQ_VHOST=/

# App
FASTAPI_TITLE="Payments Processor"
DEBUG=0
LOGURU_LEVEL=INFO
API_KEY=

# Webhook
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT_SECONDS=10
# DEV ONLY: allow private / loopback / link-local hosts as webhook targets. MUST be 0 in production.
WEBHOOK_ALLOW_PRIVATE_HOSTS=0

# Outbox dispatcher
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BACKOFF_INITIAL_SECONDS=2
OUTBOX_BACKOFF_MAX_SECONDS=60

# Consumer
CONSUMER_PREFETCH_COUNT=10
CONSUMER_MAX_RETRIES=3
CONSUMER_PROCESS_MIN_SECONDS=2
CONSUMER_PROCESS_MAX_SECONDS=5
CONSUMER_SUCCESS_PROBABILITY=0.9
